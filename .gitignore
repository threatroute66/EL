# --- Python ---
.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
build/
dist/
.python-version
pip-wheel-metadata/

# --- Test / lint caches ---
.pytest_cache/
.ruff_cache/
.mypy_cache/
.tox/
.coverage
htmlcov/

# --- Playwright MCP transient artifacts (browser snapshots, console logs) ---
.playwright-mcp/

# --- IDE / editor ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# --- EL case workspaces (per-case evidence + outputs) ---
# Each case dir under cases/ is gitignored; cases/.keep lets the dir live
cases/*/
cases/_archives/
!cases/.keep

# --- User-supplied SIGMA rule packs ---
# rules/sigma/ is where operators clone a SigmaHQ rule pack or drop
# their own rules. Content is user-supplied and often covered by
# different licenses; don't track it here.
rules/sigma/*
!rules/sigma/README.md

# --- capa rule pack (Mandiant) ---
# Cloned from https://github.com/mandiant/capa-rules; ~6 MB, Apache-2.0.
# Keep out of tree for the same licensing-drift reason as SIGMA. Setup
# instructions live in docs/capa-rules.md rather than a README inside
# the dir (so an operator clone doesn't collide with EL's doc).
rules/capa/

# --- EL ad-hoc analysis area ---
analysis/*
!analysis/.keep

# --- Provisioning snapshots (host-state captures) ---
provisioning/snapshots/snap-*/
!provisioning/snapshots/.keep

# --- Local-only Claude Code overrides + harness state ---
.claude/settings.local.json
.claude/.credentials.json
.claude/scheduled_tasks.lock
.claude/*.lock

# --- Defensive: forensic data must NEVER be committed ---
# Memory images
*.vmem
*.mem
*.raw
*.lime
*.dmp
*.kdmp
# Disk images
*.E01
*.e01
*.L01
*.l01
*.AD1
*.ad1
*.dd
*.img
*.iso
*.vhd
*.vhdx
*.vmdk
# Logs / artifacts
*.evtx
*.etl
*.plaso
# DBs that case workflows may produce outside cases/
*.kuzu
*.sqlite
*.db
# Misc evidence containers
*.zip
*.tar.gz
*.7z

# --- Editor / OS noise we don't want to track ---
nohup.out
*.pid

# Memory Baseliner stray log (auto-written to cwd by csababarta/memory-baseliner)
all.log
.lock

# --- Operator scratch / accidental working-dir leftovers ---
# scratch/ is operator working space (intermediate carves, fixture trees,
# ad-hoc analysis output). Can be many tens of GB; never belongs in the repo.
scratch/
# Stray Plaso/log2timeline log files that land at the repo root when the
# CLI is invoked from /opt/EL/ without an output dir.
log2timeline-*.log.gz
# /2/ was an accidentally-committed Android fixture stub (UAC test scratch);
# rebuild from a real UAC collection if needed, not from this path.
/2/
